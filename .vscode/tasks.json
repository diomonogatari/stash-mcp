{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/stash-mcp.slnx"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/stash-mcp.slnx"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "test: fast (skip system e2e)",
      "detail": "Unit + integration tests only; excludes the Testcontainers-backed system tests.",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/stash-mcp.slnx",
        "--filter",
        "Category!=SystemTest"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    },
    {
      "label": "test: system e2e (Docker + system.runsettings)",
      "detail": "Boots a real Bitbucket container and runs the end-to-end tests. Reads the license from tests/StashMcpServer.SystemTests/system.runsettings (copy the .example and paste a license). Requires Docker. Use THIS — the Test Explorer gutter button doesn't apply runsettings env vars, but `dotnet test --settings` does.",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/StashMcpServer.SystemTests/StashMcpServer.SystemTests.csproj",
        "--settings",
        "${workspaceFolder}/tests/StashMcpServer.SystemTests/system.runsettings",
        "--logger",
        "console;verbosity=normal"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    }
  ]
}
