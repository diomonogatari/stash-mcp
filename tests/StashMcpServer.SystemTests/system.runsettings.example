<?xml version="1.0" encoding="utf-8"?>
<!--
  Lets the VS Code C# Dev Kit Test Explorer RUN the Docker-backed system tests (otherwise they skip).

  Setup:
    1. Copy this file to "system.runsettings" (gitignored, so your license is never committed).
    2. Paste your Bitbucket Data Center timebomb license into STASH_TEST_LICENSE below.
    3. Add to VS Code settings (.vscode/settings.json or user settings):
         "dotnet.unitTests.runSettingsPath": "tests/StashMcpServer.SystemTests/system.runsettings"
    4. Reload the window. Docker must be running.

  Where to get the license — Atlassian's published timebomb licenses (free):
    https://developer.atlassian.com/platform/marketplace/timebomb-licenses-for-testing-server-apps/
    Use the "10 user Bitbucket Data Center license, expires in 3 hours" entry, copied EXACTLY
    (the page wraps the key; join it into one unbroken line or Bitbucket rejects it).

  You do NOT need a new license every 3 hours: the "3 hours" is how long a running instance stays up,
  not the string's validity. The string is reusable forever; each test run boots a fresh ~60s
  container, so the limit is never hit. (Left a manual instance up >3h? Just restart it.)
-->
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <STASH_TEST_LICENSE>PASTE_YOUR_BITBUCKET_DC_TIMEBOMB_LICENSE_HERE</STASH_TEST_LICENSE>
      <!-- Optional: raise the boot budget on slower machines (default 10). -->
      <!-- <STASH_TEST_STARTUP_TIMEOUT_MINUTES>12</STASH_TEST_STARTUP_TIMEOUT_MINUTES> -->
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
